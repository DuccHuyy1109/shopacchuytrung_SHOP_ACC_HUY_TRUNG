# ===== DATABASE =====
# Cách 1 (khuyên dùng khi deploy): Supabase/Postgres — điền chuỗi kết nối vào
# DATABASE_URL (lấy ở Supabase: Project Settings -> Database -> Connection
# string -> chọn "Transaction pooler", port 6543). Nếu có DATABASE_URL thì các
# biến DB_* bên dưới sẽ bị bỏ qua.
# Ví dụ:
# DATABASE_URL=postgresql://postgres.xxxx:[MẬT-KHẨU]@aws-0-...pooler.supabase.com:6543/postgres
DATABASE_URL=

# Cách 2 (dev local): SQL Server / SSMS
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost
DB_NAME=ShopAccHuyTrungDB
DB_USERNAME=sa
DB_PASSWORD=
DB_PORT=1433
# Set true to use Windows Authentication instead of UID/PWD
DB_TRUSTED_CONNECTION=false

# ===== JWT / SECURITY =====
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== APP =====
# Đặt "production" khi deploy: tắt trang /docs & /redoc (giấu schema API).
ENVIRONMENT=development
PROJECT_NAME=Shop Acc Huy Trung
BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=uploads

# ===== DEFAULT ADMIN (seeded on first run) =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_EMAIL=admin@shopacchuytrung.com

# ===== TELEGRAM (order & contact notifications) =====
# Create a bot via @BotFather to get the token, then get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== SUPABASE STORAGE (lưu ảnh) =====
# Để trống -> ảnh lưu vào ổ đĩa local (uploads/).
# Điền đủ -> ảnh tự lưu lên Supabase Storage (dùng khi deploy).
# Lấy service_role key ở: Project Settings -> API -> service_role (BÍ MẬT).
# Nhớ bật "Public bucket" cho bucket ảnh.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=image
